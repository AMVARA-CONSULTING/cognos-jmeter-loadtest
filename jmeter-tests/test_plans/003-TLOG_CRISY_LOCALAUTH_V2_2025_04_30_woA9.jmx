                  <stringProp name="script">if ( &quot;${vars.get(&apos;STATUS_CODE&apos;)}&quot; ==~ /2[0-9][0-9]/ ) {
	log.info(&quot;Thread #${__threadNum} - SalesOrderItemUUID1 =&gt; ${vars.get(&apos;SalesOrderItemUUID1&apos;)}, SalesOrderItemUUID2 =&gt; ${vars.get(&apos;SalesOrderItemUUID2&apos;)}, SalesOrderItemUUID3 =&gt; ${vars.get(&apos;SalesOrderItemUUID3&apos;)} (${vars.get(&apos;loop_counter&apos;)}/${loops}).&quot;);
	// from the ammount of row get the number of pages setting max rows per page to 5000
	int numberOfPages = Math.ceil(vars.get(&apos;TotalSalesOrderItems&apos;).toInteger() / 5000);
	vars.put(&quot;numberOfPages&quot;, &quot;${numberOfPages}&quot;);
	log.info(&quot;Total number of pages to export =&gt; ${vars.get(&apos;numberOfPages&apos;)}.&quot;)
} else {
     log.info(&quot;=====================================&quot;)
	log.error(sampler.getName().toString()+&quot; - Page loaded with status code ${vars.get(&apos;STATUS_CODE&apos;)}.&quot;);
	log.info(&quot;Response: &quot;+prev.getResponseDataAsString())
	prev.setSuccessful(false)
	prev.setResponseMessage(sampler.getName().toString() + &quot; - Page loaded with status code ${vars.get(&apos;STATUS_CODE&apos;)}.&quot;)
     log.info(&quot;=====================================&quot;)
}</stringProp>
                </JSR223PostProcessor>
