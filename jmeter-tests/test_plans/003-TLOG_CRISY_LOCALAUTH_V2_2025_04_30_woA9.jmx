        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Z2-LOGIN-1-0" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import org.openqa.selenium.By
import org.openqa.selenium.Cookie
import org.openqa.selenium.JavascriptExecutor
import org.openqa.selenium.WebElement
import org.openqa.selenium.support.ui.ExpectedConditions
import org.openqa.selenium.support.ui.WebDriverWait
import java.time.Duration
import org.openqa.selenium.chrome.ChromeOptions
import java.net.URL


import org.openqa.selenium.WebDriver;
import org.openqa.selenium.remote.RemoteWebDriver;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.remote.DesiredCapabilities;
import org.openqa.selenium.chrome.ChromeOptions;
import org.openqa.selenium.By

import org.apache.jmeter.services.FileServer;
import java.io.BufferedReader;
import java.io.InputStreamReader;

// === 1. Read params from config.properties file ===
Properties props = new Properties()
File configFile = new File(&quot;config.properties&quot;)

if (configFile.exists()) {
    FileInputStream fis = new FileInputStream(configFile)
    props.load(fis)
    fis.close()
    log.info(&quot;Config loaded from file&quot;)
} else {
    log.warn(&quot;Config file not found. Using JMeter variables.&quot;)
}

def username = props.getProperty(&quot;username&quot;, vars.get(&quot;username&quot;))
def password = props.getProperty(&quot;password&quot;, vars.get(&quot;password&quot;))
def webdriverHubUrl = props.getProperty(&quot;webdriver_hub_url&quot;, vars.get(&quot;webdriver_hub_url&quot;))


// Set up ChromeOptions for the browser
ChromeOptions options = new ChromeOptions();
//options.addArguments(&quot;--headless&quot;); // Optional: Run Chrome in headless mode
//options.addArguments(&quot;--disable-gpu&quot;); // Optional: Disable GPU for headless mode
options.addArguments(&apos;--user-data-dir=/home/seluser/selenium-&apos; + System.currentTimeMillis())


WebDriver browser

try {
	// Use remote WebDriver (in docker container for example)
	log.info(&quot;Using remote WebDriver...&quot;)
	URL remoteWebDriverUrl = new URL(vars.get(&quot;webdriver_hub_url&quot;))
	browser = new RemoteWebDriver(remoteWebDriverUrl, options)

	log.info(&quot;${__threadNum}  - Setting url ...&quot;)

} catch (Exception e) {
    log.error(&quot;Error while initializing WebDriver: &quot; + e.getMessage(), e)
    throw e
}



String testPlanFileDir = FileServer.getFileServer().getBaseDir();
log.info(&quot;Thread #${__threadNum} Path: ${testPlanFileDir}&quot;);


Duration timeout = Duration.ofSeconds(60)
WebDriverWait wait = new WebDriverWait(browser, timeout)

browser.get(&quot;${protocol}://${servername}/site?siteId=e71e067a-1fce-49fa-8a30-8a6437b26b80&quot;)

wait.until(ExpectedConditions.and(
	ExpectedConditions.urlMatches(/login\.businessid\.daimlertruck\.com\//),
	ExpectedConditions.urlMatches(/2c_1a_signin/)
))
log.info(&quot;Thread #${__threadNum} - the Yellow button page has been reached&quot;)



WebElement usernameField = wait.until(ExpectedConditions.presenceOfElementLocated(
    By.xpath(&quot;//input[@id=&apos;signInName&apos;]&quot;)))

log.info(&quot;Thread #${__threadNum} Username field found. Entering the username...&quot;)
usernameField.sendKeys(username)

WebElement continueButton = wait.until(ExpectedConditions.presenceOfElementLocated(
By.xpath(&quot;//button[@id=&apos;next-btn&apos;]&quot;)))
log.info(&quot;Thread #${__threadNum} Continue button found. Clicking the button...&quot;)
continueButton.click()

WebElement passField = wait.until(ExpectedConditions.presenceOfElementLocated(
    By.xpath(&quot;//input[@id=&apos;password&apos; and @type=&apos;password&apos;]&quot;)))
log.info(&quot;Thread #${__threadNum} Password field found. Entering the password...&quot;)
passField.sendKeys(password)

WebElement signInButton = wait.until(ExpectedConditions.presenceOfElementLocated(
    By.xpath(&quot;//button[@type=&apos;submit&apos; and @form=&apos;localAccountForm&apos;]&quot;)))
log.info(&quot;Thread #${__threadNum} Sign-in button found. Clicking the button...&quot;)
signInButton.click()



wait.until(ExpectedConditions.presenceOfElementLocated(
    By.xpath(&quot;//span[@id=&apos;__tile20-title-inner&apos; and text()=&apos;Sales Orders&apos;]&quot;)))
    
vars.put(&apos;LOGIN_OK&apos;, &quot;TRUE&quot;)

wait.until(ExpectedConditions.and(
    ExpectedConditions.urlContains(&quot;${protocol}://${servername}/site&quot;)
))
log.info(&quot;Thread #${__threadNum} logged in successfully&quot;)

Set&lt;org.openqa.selenium.Cookie&gt; cookies = browser.manage().getCookies()
int index = 1

cookies.each { cookie -&gt;
    log.info(&quot;Thread #${__threadNum} Cookie Name: ${cookie.getName()}&quot;)
    log.info(&quot;Thread #${__threadNum} Cookie Value: ${cookie.getValue()}&quot;)
    log.info(&quot;Thread #${__threadNum} Domain: ${cookie.getDomain()}&quot;)
    log.info(&quot;Thread #${__threadNum} Path: ${cookie.getPath()}&quot;)
    log.info(&quot;Thread #${__threadNum} Expiry: ${cookie.getExpiry()}&quot;)
    log.info(&quot;Thread #${__threadNum} Is Secure: ${cookie.isSecure()}&quot;)
    log.info(&quot;Thread #${__threadNum} --------------------------------&quot;)

    if (cookie.getName() in [&quot;JSESSIONID&quot;, &quot;__VCAP_ID__&quot;]) {
        vars.put(cookie.getName(), cookie.getValue())
        log.info(&quot;Thread #${__threadNum} setting var ${cookie.getName()}: &quot; + cookie.getValue())
    }

    index++
}

vars.put(&quot;cookie_count&quot;, cookies.size().toString())
log.info(&quot;Thread #${__threadNum} vars JSESSIONID: &quot; + vars.get(&quot;JSESSIONID&quot;))
log.info(&quot;Thread #${__threadNum} vars __VCAP_ID__: &quot; + vars.get(&quot;__VCAP_ID__&quot;))
</stringProp>
