log.info(&quot;Thread #${__threadNum} --------------------------------&quot;)

log.info(&quot;Thread #${__threadNum} Cookie Name: JSESSIONID&quot;)
log.info(&quot;Thread #${__threadNum} Cookie Value: &quot; + vars.get(&quot;JSESSIONID&quot;))
log.info(&quot;Thread #${__threadNum} Domain: trucklog-crisy-dtag-pre-prod-b7665m95.launchpad.cfapps.eu10.hana.ondemand.com&quot;)
log.info(&quot;Thread #${__threadNum} Path: /&quot;)
