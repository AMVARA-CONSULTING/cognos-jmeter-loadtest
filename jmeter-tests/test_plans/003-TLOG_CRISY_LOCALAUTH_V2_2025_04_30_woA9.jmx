            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler -Generate Purchase Order By Customer" enabled="false">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import java.util.Random;
def startingDigit = 1
if (startingDigit &lt; 1 || startingDigit &gt; 9) {
    throw new IllegalArgumentException(&quot;Starting digit must be between 1 and 9&quot;);
}

def random = new Random();
def remainingDigits = random.nextInt(9000) + 1000; // Generate a random number between 1000 and 9999
def fiveDigitNumber = startingDigit * 10000 + remainingDigits;


// Set the JMeter variable (add 1 for human-readable month)
vars.put(&quot;PurchaseOrderByCustomer&quot;, String.valueOf(fiveDigitNumber))
log.info(&quot;PurchaseOrderByCustomer: &quot; + String.valueOf(fiveDigitNumber))</stringProp>
            </JSR223Sampler>
