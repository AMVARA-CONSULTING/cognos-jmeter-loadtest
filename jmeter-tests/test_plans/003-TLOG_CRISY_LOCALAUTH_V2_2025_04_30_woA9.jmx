        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler - todayDate" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">/* Create todays date as 2024-07-05 to be used in subsequent filtering */
import java.text.SimpleDateFormat
import java.util.Date

// Create a date format
def dateFormat = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;)

// Get today&apos;s date
def today = new Date()

// Format the date
def formattedDate = dateFormat.format(today)

// Set the JMeter variable
vars.put(&quot;todayDate&quot;, formattedDate)
log.info(&quot;Filtering to Todays date: ${vars.get(&apos;todayDate&apos;)}&quot;)
log.info(&quot;Filtering to SoldAndShipToParty: ${vars.get(&apos;SoldAndShipToParty&apos;)}&quot;)
</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="PARAMETER - Previous Month Dates" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">/* Create todays date as 2024-07-05 to be used in subsequent filtering */
import java.text.SimpleDateFormat
import java.util.Date
import java.time.LocalDate;
import java.time.YearMonth;
import java.time.format.DateTimeFormatter;

// Extract the month number (0-based indexing)
def today = LocalDate.now();

// Explicitly set the year and month to September 2024
def specificMonth = YearMonth.of(2024, 9);

// Get the start and end dates of the specified month
def specificMonthStart = specificMonth.atDay(1);
def specificMonthEnd = specificMonth.atEndOfMonth();

// Format the dates
def formatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;);
def formattedStart = specificMonthStart.format(formatter);
def formattedEnd = specificMonthEnd.format(formatter);

log.info(&quot;Previous month start: &quot; + formattedStart);
log.info(&quot;Previous month end: &quot; + formattedEnd);


// Set the JMeter variable (add 1 for human-readable month)
vars.put(&quot;specificMonthStart&quot;, formattedStart)
vars.put(&quot;specificMonthEnd&quot;, formattedEnd)</stringProp>
        </JSR223Sampler>
        <hashTree/>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="PARAMETER - 14 day previous dates" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.time.LocalDate
import java.time.format.DateTimeFormatter

// Get today&apos;s date
def today = LocalDate.now()

// Get the date 14 days prior
def fourteenDaysAgo = today.minusDays(14)

// Format the dates
def formatter = DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;)
def formattedToday = today.format(formatter)
def formattedFourteenDaysAgo = fourteenDaysAgo.format(formatter)

log.info(&quot;Today&apos;s date: &quot; + formattedToday)
log.info(&quot;Date 14 days ago: &quot; + formattedFourteenDaysAgo)

// Set the JMeter variable
vars.put(&quot;TodayDate&quot;, formattedToday)
vars.put(&quot;FourteenDaysAgoDate&quot;, formattedFourteenDaysAgo)

log.info(&quot;14 day previous date : &quot; + formattedFourteenDaysAgo);
log.info(&quot;Today Date: &quot; + formattedToday);


// Extra logic to put the needed values into datestart and dateend
if (vars.get(&quot;filtertype&quot;).equalsIgnoreCase(&quot;month&quot;)) {
    vars.put(&quot;datestart&quot;, formattedFourteenDaysAgo);
    vars.put(&quot;dateend&quot;, formattedToday);
} else if (vars.get(&quot;filtertype&quot;).equalsIgnoreCase(&quot;14days&quot;)) {
    vars.put(&quot;datestart&quot;, formattedFourteenDaysAgo);
    vars.put(&quot;dateend&quot;, formattedToday);
}




