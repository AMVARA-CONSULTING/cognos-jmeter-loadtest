log.info(&quot;Thread #${__threadNum} Cookie Name: __VCAP_ID__&quot;)
log.info(&quot;Thread #${__threadNum} Cookie Value: &quot; + vars.get(&quot;__VCAP_ID__&quot;))
log.info(&quot;Thread #${__threadNum} Domain: trucklog-crisy-dtag-pre-prod-b7665m95.launchpad.cfapps.eu10.hana.ondemand.com&quot;)
log.info(&quot;Thread #${__threadNum} Path: /&quot;)
log.info(&quot;Thread #${__threadNum} Expiry: null&quot;)
log.info(&quot;Thread #${__threadNum} Is Secure: true&quot;)
log.info(&quot;Thread #${__threadNum} --------------------------------&quot;)
</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
