                <hashTree/>
                <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor to extract 3 unique UUIDs" enabled="true">
                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput

// Get the HTTP response from the previous sampler
def response = prev.getResponseDataAsString()

// Log the raw response (for debugging purposes)
// log.info(&quot;Raw HTTP Response: ${response}&quot;)

// Extract the JSON part from the multipart response
def jsonResponse
def jsonStart = response.indexOf(&apos;{&apos;)
def jsonEnd = response.lastIndexOf(&apos;}&apos;) + 1

if (jsonStart != -1 &amp;&amp; jsonEnd != -1 &amp;&amp; jsonStart &lt; jsonEnd) {
    jsonResponse = response.substring(jsonStart, jsonEnd)
} else {
	log.info(&quot; ---------------------------------- &quot;)
	log.info(&quot; ---------------------------------- &quot;)
	log.info(&quot; ---------------------------------- &quot;)
     log.error(&quot;Failed to find JSON in the response&quot;)
     log.info(&quot;Raw HTTP Response: ${response}&quot;)
	log.info(&quot; ---------------------------------- &quot;)
	log.info(&quot; ---------------------------------- &quot;)
	log.info(&quot; ---------------------------------- &quot;)
     return
}

// Log the extracted JSON (for debugging purposes)
// log.info(&quot;Extracted JSON: ${jsonResponse}&quot;)

// Preprocess the JSON string to handle potential issues
// def cleanJsonString = jsonResponse.replaceAll(/\\/Date\(\d+\+\d+\)\/$/, &apos;&apos;)  // Remove date format if present
// cleanJsonString = cleanJsonString.replaceAll(/\\/, &apos;&apos;)  // Remove backslashes

// Parse the JSON string
def jsonSlurper = new JsonSlurper()
def jsonData

try {
    jsonData = jsonSlurper.parseText(jsonResponse)
} catch (Exception e) {
	log.info(&quot; ---------------------------------- &quot;)
	log.info(&quot; ---------------------------------- &quot;)
	log.info(&quot; ---------------------------------- &quot;)
     log.error(&quot;Failed to parse JSON response: ${e.message}&quot;)
	log.info(&quot;Extracted JSON: ${jsonResponse}&quot;)
	log.info(&quot; ---------------------------------- &quot;)
	log.info(&quot; ---------------------------------- &quot;)
	log.info(&quot; ---------------------------------- &quot;)
     return
}

// Use a set to store unique UUIDs
def uniqueUuids = new LinkedHashSet()  // LinkedHashSet maintains insertion order

// Extract SalesOrderUUIDs and add them to the set
if (jsonData.d &amp;&amp; jsonData.d.results) {
    jsonData.d.results.each { entry -&gt;
        if (entry.SalesOrderUUID) {
            uniqueUuids.add(entry.SalesOrderUUID)
        }
    }
} else {
	log.info(&quot; ---------------------------------- &quot;)
	log.info(&quot; ---------------------------------- &quot;)
	log.info(&quot; ---------------------------------- &quot;)
     log.warn(&quot;Unexpected JSON structure&quot;)
	log.info(&quot; ---------------------------------- &quot;)
	log.info(&quot; ---------------------------------- &quot;)
	log.info(&quot; ---------------------------------- &quot;)
}

uniqueUuids.each { entry -&gt;
	log.info(&quot;UUID entry: &quot; + entry)
}
log.info(&quot; ---------------------------------- &quot;)

// Get the first 3 unique UUIDs
def threeUniqueUuids = uniqueUuids.take(3)

// Print the extracted UUIDs to the JMeter log
log.info(&quot;Extracted UUIDs:&quot;)
threeUniqueUuids.each { uuid -&gt;
    log.info(uuid)
}

// Optionally, set the UUIDs as JMeter variables
threeUniqueUuids.eachWithIndex { uuid, index -&gt;
    props.put(&quot;ExtractedUUID${index + 1}&quot;, uuid)
}
vars.put(&quot;SalesOrderItemUUID1&quot;, threeUniqueUuids[0])
vars.put(&quot;SalesOrderItemUUID2&quot;, threeUniqueUuids[1])
vars.put(&quot;SalesOrderItemUUID3&quot;, threeUniqueUuids[2])</stringProp>
                </JSR223PostProcessor>
